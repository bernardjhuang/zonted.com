# Cloudflare Pages _headers — security + caching policy for zonted.com.
# Same gap the stakes-priming audit caught on VeracityAPI; closing it here.

/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()
  X-XSS-Protection: 1; mode=block
  Cross-Origin-Opener-Policy: same-origin
  # CSP intentionally omitted in v1 — inline styles + onclick handlers are
  # widespread in the post template and need to be migrated to external JS/CSS
  # before a strict CSP can ship without breaking the site. See audit P2 #15.

# Long-lived static assets get aggressive caching
/css/*
  Cache-Control: public, max-age=2592000, must-revalidate

/js/*
  Cache-Control: public, max-age=2592000, must-revalidate

# Post images + repo assets: long cache, but no `immutable` — gives Bernard
# an escape hatch if he ever swaps an image at the same path (immutable
# would lock returning visitors out of the new version until cache eviction).
/posts/*/img/*
  Cache-Control: public, max-age=31536000

/assets/*
  Cache-Control: public, max-age=31536000

# Never index scaffolding
/_templates/*
  X-Robots-Tag: noindex

/prototype/*
  X-Robots-Tag: noindex
